@model VereinKasseScaffolding.Models.Zahlung

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Zahlung</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Betrag" class="control-label"></label>
                <input asp-for="Betrag" class="form-control" />
                <span asp-validation-for="Betrag" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Datum" class="control-label"></label>
                <input asp-for="Datum" class="form-control" />
                <span asp-validation-for="Datum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Beschreibung" class="control-label"></label>
                <input asp-for="Beschreibung" class="form-control" />
                <span asp-validation-for="Beschreibung" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MitgliedId" class="control-label"></label>
                <select asp-for="MitgliedId" class="form-control" asp-items="ViewBag.MitgliedId"></select>
                <span asp-validation-for="MitgliedId" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IstEinzahung" /> @Html.DisplayNameFor(model => model.IstEinzahung)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
